# ──────────────────────────────────────────────────────────────────────────────
# ORIA Flask Backend — Environment Variables
# Copy this file to config.env and fill in your real values
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Database URL
DATABASE_URL=sqlite:///users.db

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-flask-secret-key-here

# Shared API key for Telegram Bot ↔ Flask communication
# Must match BOT_API_KEY in the bot's .env file
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BOT_API_KEY=your-bot-api-key-here

# Telegram Bot Token (from @BotFather) — used for WebApp HMAC signature validation
# This is NOT the same as BOT_API_KEY above!
BOT_TOKEN=your-telegram-bot-token-here

# Super Admin email (auto-promoted to superadmin role on app start)
# Must match the email of an existing registered user
SUPER_ADMIN_EMAIL=your-admin-email@example.com

# Flask environment (set to 'production' for live deployment)
FLASK_ENV=development
